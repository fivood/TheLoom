  "flows": [
    {
      "id": "s6ju9btoe8il",
      "name": "DEMO · 雨夜寻人",
      "nodes": [
        {
          "id": "j693c4g9e8il",
          "type": "fragment",
          "data": {
            "title": "ACT 0 · 遮阳篷下",
            "text": "伦敦的雨季长得就像基金会迟迟走不到尽头的走廊。我叫塞梅尔维斯,基金会高级调查员,今天放假。后勤部的怪味巧克力还黏在牙上,兜里那部德制直板手机突然震了。"
          }
        },
        {
          "id": "40b9cprse8il",
          "type": "dialogue",
          "data": {
            "title": "第一条短信 · 16:09",
            "text": "我需要你的帮助,亲爱的塞梅尔维斯 @-‵-,--",
            "speakerId": "4yguilkne8il"
          }
        },
        {
          "id": "ohfhggr8e8il",
          "type": "dialogue",
          "data": {
            "title": "回敬一句",
            "text": "堂堂瓦伦缇娜也有做不到的事吗?",
            "speakerId": "k7aflbive8il",
            "technicalName": "reply_mock"
          }
        },
        {
          "id": "lfep0tm6e8il",
          "type": "dialogue",
          "data": {
            "title": "仅存的回复",
            "text": "……?",
            "speakerId": "k7aflbive8il",
            "technicalName": "reply_dot"
          }
        },
        {
          "id": "7riql0yse8il",
          "type": "hub",
          "data": {
            "title": "装没看见",
            "technicalName": "reply_silent"
          }
        },
        {
          "id": "3xi5zd8ye8il",
          "type": "dialogue",
          "data": {
            "title": "第二条短信",
            "text": "很高兴你没把手机扔了。亲爱的,我好像被困在一个讨厌神秘术的盒子里。若死前只能与发霉的空气作伴,只好请求你发挥调查员本能了。帮我出去,价钱随你开,如何?",
            "speakerId": "4yguilkne8il"
          }
        },
        {
          "id": "ziclyouke8il",
          "type": "fragment",
          "data": {
            "title": "谜题 · 时间戳分析",
            "text": "双击进入解谜子流程。判断错误不会卡关——但会晚出发。",
            "technicalName": "puzzle_timestamp",
            "sub": {
              "nodes": [
                {
                  "id": "egwwl266e8il",
                  "type": "fragment",
                  "data": {
                    "title": "便条纸展开",
                    "text": "第一条:发送 16:09,接收 16:15。第二条:发送 16:27,接收 16:32。伦敦市中心,五六分钟的延迟不正常。拨号尝试:「您拨打的号码暂时无法接通——」"
                  }
                },
                {
                  "id": "b1r7cu7we8il",
                  "type": "condition",
                  "data": {
                    "title": "短信能到,电话不通?",
                    "text": "signal_blocked == true"
                  }
                },
                {
                  "id": "vz5x1qnfe8il",
                  "type": "exit",
                  "data": {
                    "title": "屏蔽确认"
                  }
                },
                {
                  "id": "qsi99gg4e8il",
                  "type": "hub",
                  "data": {
                    "title": "只是英国的信号"
                  }
                }
              ],
              "edges": [
                {
                  "id": "ezaox55le8il",
                  "source": "egwwl266e8il",
                  "target": "b1r7cu7we8il"
                },
                {
                  "id": "f28myr1ve8il",
                  "source": "b1r7cu7we8il",
                  "target": "vz5x1qnfe8il",
                  "sourceHandle": "true",
                  "label": "存在物理或神秘术屏蔽"
                },
                {
                  "id": "cpmge5z6e8il",
                  "source": "b1r7cu7we8il",
                  "target": "qsi99gg4e8il",
                  "sourceHandle": "false",
                  "label": "再等等看"
                }
              ]
            }
          }
        },
        {
          "id": "bwyld4tre8il",
          "type": "instruction",
          "data": {
            "title": "记下地址 · 察觉延迟",
            "text": "has_address = true; delay_noticed = true"
          }
        },
        {
          "id": "7bkyt317e8il",
          "type": "dialogue",
          "data": {
            "title": "第三条短信 · 迟来的地址",
            "text": "半小时前我确实身在伦敦。那张肇事的软盘应该还在原处(还有我的手提包)。交易所地址是威斯敏斯特区白厅七号——噢我那朋友叫费瑟斯顿霍(Featherstonhaugh)",
            "speakerId": "4yguilkne8il"
          }
        },
        {
          "id": "kn81kvwqe8il",
          "type": "instruction",
          "data": {
            "title": "迟来的出发",
            "text": "has_address = true; late_start = true; battery -= 10"
          }
        },
        {
          "id": "fla02q6ye8il",
          "type": "fragment",
          "data": {
            "title": "ACT 2 · 白厅七号门厅",
            "text": "维多利亚砖红建筑,没有门牌。戴金属框眼镜的接待员正用两根食指一下一下敲键盘,铭牌上是「菲尔」「比尔」「威尔」之类一眼就会记混的名字。"
          }
        },
        {
          "id": "y1r7qytle8il",
          "type": "dialogue",
          "data": {
            "title": "亮明身份",
            "text": "是,我是塞梅尔维斯,今天是来找她的。……签名可真是浪费生命,不过跟 Featherstonhaugh 一比似乎又没那么可悲。",
            "speakerId": "k7aflbive8il",
            "technicalName": "front_honest"
          }
        },
        {
          "id": "e2zuvuxee8il",
          "type": "check",
          "data": {
            "title": "谎称有预约",
            "text": "「范肖先生半小时前刚约的我,雨天口信慢,您懂的。」",
            "checkExpr": "cunning",
            "checkDc": 9
          }
        },
        {
          "id": "z26mm6uge8il",
          "type": "dialogue",
          "data": {
            "title": "接待员推了推镜框",
            "text": "没有预约的话,恐怕……啊,等等,您是塞梅尔维斯小姐?瓦伦缇娜女士吩咐过,要按她的级别接待您。",
            "speakerId": "h8bxbn0ke8il"
          }
        },
        {
          "id": "nkjj6e4me8il",
          "type": "check",
          "data": {
            "title": "趁乱直接上楼",
            "text": "接待员敲键盘的间隙足够长。红检定:只有一次机会,失败会惊动整个门厅。",
            "technicalName": "sneak_upstairs",
            "checkExpr": "resolve",
            "checkDc": 11,
            "checkRed": true
          }
        },
        {
          "id": "ggdjq6vbe8il",
          "type": "instruction",
          "data": {
            "title": "惊动门厅",
            "text": "alarm = true"
          }
        },
        {
          "id": "bh13b7m3e8il",
          "type": "fragment",
          "data": {
            "title": "ACT 2 · 二楼书房",
            "text": "秃头老绅士在排满书柜的休息室来回踱步,挠着后脑勺仅存的几缕白发。沙发上放着那只手提包,书桌上是五英寸黑色软盘。"
          }
        },
        {
          "id": "r9txy7xge8il",
          "type": "dialogue",
          "data": {
            "title": "法律风险告知书",
            "text": "我可以不问软盘的来历。但那次使用机会已经被瓦伦缇娜女士「替你」用掉了——如果您觉得价格不公道,我非常乐意当场拟一份法律风险告知书,以瓦伦缇娜女士的名义。",
            "speakerId": "k7aflbive8il",
            "technicalName": "legal_threat"
          }
        },
        {
          "id": "oq6lutrse8il",
          "type": "check",
          "data": {
            "title": "亮证件施压",
            "text": "基金会调查员证件拍在桌上。若刚才惊动过门厅(alarm),他的戒备会让施压更难。",
            "checkExpr": "resolve - (alarm ? 2 : 0)",
            "checkDc": 9
          }
        },
        {
          "id": "rne7xhyie8il",
          "type": "check",
          "data": {
            "title": "替他着想的说法",
            "text": "「您也不希望瓦伦缇娜女士在这失踪的消息传开吧?配合我,我替您在她面前美言几句。」",
            "checkExpr": "cunning + 1",
            "checkDc": 10
          }
        },
        {
          "id": "pi8xlpfie8il",
          "type": "dialogue",
          "data": {
            "title": "范肖投降",
            "text": "呃……塞梅尔维斯小姐,只要别让瓦伦缇娜女士投诉,软盘随你处置,现在它是你的了。",
            "speakerId": "h8bxbn0ke8il"
          }
        },
        {
          "id": "gw5fk4n8e8il",
          "type": "dialogue",
          "data": {
            "title": "范肖全招",
            "text": "软盘是三个月前一位「处理非生物危险品」的中间人抵的账……编号我从没敢查。手提包和软盘您都拿走,拜托了。",
            "speakerId": "h8bxbn0ke8il"
          }
        },
        {
          "id": "ct586poze8il",
          "type": "dialogue",
          "data": {
            "title": "行规在此",
            "text": "这行的要求不能透露供货商情报,请恕我无法说明,塞梅尔维斯小姐。",
            "speakerId": "h8bxbn0ke8il"
          }
        },
        {
          "id": "e7gc27gde8il",
          "type": "fragment",
          "data": {
            "title": "软盘与手提包",
            "text": "五英寸黑色软盘,基金会与拉普拉斯的徽记,编号 LSCC-TPT-LDN-ERR。末尾的 ERR,在任何行业都不是个好词。",
            "technicalName": "got_floppy"
          }
        },
        {
          "id": "4gniggzee8il",
          "type": "fragment",
          "data": {
            "title": "ACT 3 · 雨中的选择",
            "text": "大本钟傍晚五点的钟声被雨吞了尾音。距离求救已近一小时。是先走官方流程,还是直接下去?"
          }
        },
        {
          "id": "a18mvsb0e8il",
          "type": "fragment",
          "data": {
            "title": "致电技术档案室",
            "text": "编号查询:堤岸工程时期的收容室,建在铁路隧道和下水道主管之间的夹层,墙体浇筑时混入抑制神秘术的符文。「如果您确认了具体位置,可以开启通讯器的定位发送功能,我们会派人前往。」",
            "technicalName": "call_archive"
          }
        },
        {
          "id": "lswko5afe8il",
          "type": "hub",
          "data": {
            "title": "官方流程太慢",
            "technicalName": "skip_protocol"
          }
        },
        {
          "id": "n5ugy91qe8il",
          "type": "fragment",
          "data": {
            "title": "ACT 4 · 查令十字 · 维修通道",
            "text": "站台最西端的铁门,螺旋台阶,然后是完全的黑暗。双击进入导航子流程。",
            "sub": {
              "nodes": [
                {
                  "id": "snhcjbyge8il",
                  "type": "fragment",
                  "data": {
                    "title": "铁门之后",
                    "text": "空气污浊的狭长通道,漂浮的尘埃或许都来自上个世纪。血食怪的夜视在纯黑里也只是扩大虚无——导航靠手、靠耳朵、靠头顶几分钟一次的列车振动。"
                  }
                },
                {
                  "id": "7eqlrs2re8il",
                  "type": "check",
                  "data": {
                    "title": "摸墙辨向",
                    "text": "右手扶墙,数着振动往南。白检定:走错还能折返重试,但要付出时间(和瓦伦缇娜的电量)。",
                    "checkExpr": "focus",
                    "checkDc": 8
                  }
                },
                {
                  "id": "fz06m21ye8il",
                  "type": "hub",
                  "data": {
                    "title": "死路 · 折返"
                  }
                },
                {
                  "id": "dw1hcsrwe8il",
                  "type": "condition",
                  "data": {
                    "title": "她的手机还有电吗?",
                    "text": "battery > 0"
                  }
                },
                {
                  "id": "tp8notm7e8il",
                  "type": "dialogue",
                  "data": {
                    "title": "一个字的短信",
                    "text": "血",
                    "speakerId": "4yguilkne8il"
                  }
                },
                {
                  "id": "ien4ud4be8il",
                  "type": "check",
                  "data": {
                    "title": "嗅觉搜索",
                    "text": "没有短信指引,只能张开鼻腔在裂缝间捕捉那股她认得的气味。白检定,可反复尝试。",
                    "checkExpr": "focus + 2",
                    "checkDc": 9
                  }
                },
                {
                  "id": "8rlaso67e8il",
                  "type": "hub",
                  "data": {
                    "title": "只有铁锈味"
                  }
                },
                {
                  "id": "kx7pmjlke8il",
                  "type": "fragment",
                  "data": {
                    "title": "找到裂缝",
                    "text": "列车交会的瞬间,裂缝张开一毫米,血腥味涌进通道——只有淡淡的一抹,若不是对这股血液来源有本能的记忆,她会把它当成铁轨润滑油的金属味忽略掉。",
                    "technicalName": "found_crack"
                  }
                },
                {
                  "id": "6gohf5hze8il",
                  "type": "condition",
                  "data": {
                    "title": "有支援渠道吗?",
                    "text": "backup_ready == true"
                  }
                },
                {
                  "id": "fbzrfhjhe8il",
                  "type": "instruction",
                  "data": {
                    "title": "按下定位发送",
                    "text": "position_sent = true"
                  }
                },
                {
                  "id": "g2yy4ybme8il",
                  "type": "exit",
                  "data": {
                    "title": "裂缝前就位"
                  }
                }
              ],

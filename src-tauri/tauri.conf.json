{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TheLoom",
  "version": "0.8.0",
  "identifier": "com.fivood.theloom",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCQkI3QzBEQkQxRDRCODgKUldTSVN4MjlEWHk3bS9tdVNVQ3E1bkZiMCthV2diRVNjK0U1c2w2QW9NL0JUclMvb2lUZk5YbXMK",
      "endpoints": [
        "https://theloom.pages.dev/api/update/{{target}}/{{current_version}}"
      ]
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "叙事织机 TheLoom",
        "width": 1440,
        "height": 900,
        "minWidth": 940,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
